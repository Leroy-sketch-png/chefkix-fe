# This file documents the environment variables required by the application.
# Create a .env.local file for your local development environment.

NEXT_PUBLIC_BASE_URL=http://localhost:8080
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# WebRTC relay. A public TURN URL is required for separate-network demo devices.
NEXT_PUBLIC_TURN_URL=turn:localhost:3478?transport=udp
NEXT_PUBLIC_TURN_USERNAME=chefkix
NEXT_PUBLIC_TURN_CREDENTIAL=CHANGE_ME
