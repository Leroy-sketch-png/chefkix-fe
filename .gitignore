_*.txt

# Playwright visual testing outputs
tests/visual/.run-state.json
tests/visual/raw-captures/
tests/visual/raw-archive/
tests/visual/shots/
tests/visual/ai-review/
tests/visual/test-results/
tests/visual/report/
